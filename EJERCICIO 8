#include <iostream>
#include <string>
using namespace std;

int main() {

    string nombre;
    float nota1, nota2, nota3, promedio = 0;
    float asistencia;
    string proyectoFinal, plagio;
    string estado, observacionD = "", observacionR = "";

    cout << "Ingresa tu nombre: ";
    cin >> nombre;

    cout << "Ingresa la nota 1: ";
    cin >> nota1;

    cout << "Ingresa la nota 2: ";
    cin >> nota2;

    cout << "Ingresa la nota 3: ";
    cin >> nota3;

    cout << "Ingrese porcentaje de asistencia: ";
    cin >> asistencia;

    cout << "¿Entregaste el proyecto final? (si/no): ";
    cin >> proyectoFinal;

    cout << "¿Has cometido plagio? (si/no): ";
    cin >> plagio;

    if (plagio == "si") {
        estado = "Reprobado automaticamente";
        observacionD = "El proyecto no puede tener plagio";
    }
    else {

        if (asistencia < 70) {
            estado = "Reprobado";
            observacionD = "Asista mas a clases";
        }
        else {

            if (proyectoFinal == "no") {
                estado = "Recuperacion";
                observacionR = "Entregar trabajos a tiempo";
            }
            else {
                promedio = (nota1 + nota2 + nota3) / 3;

                if (promedio >= 7) {
                    estado = "Aprobado";
                }
                else if (promedio >= 5) {
                    estado = "Recuperacion";
                }
                else {
                    estado = "Reprobado";
                }
            }
        }
    }

    // Rendimiento irregular
    if ((nota1 == 10 || nota2 == 10 || nota3 == 10) &&
        ((nota1 < 4 && nota2 < 4) ||
         (nota1 < 4 && nota3 < 4) ||
         (nota2 < 4 && nota3 < 4))) {

        observacionR = "Rendimiento irregular";
    }

    // Caso excelente
    if (nota1 >= 9 && nota2 >= 9 && nota3 >= 9 && asistencia >= 95) {
        estado = "Felicitaciones, usted esta aprobado";
    }

    cout << "\nEstudiante: " << nombre << endl;
    cout << "Promedio: " << promedio << endl;
    cout << "Estado academico: " << estado << endl;
    cout << "Observacion disciplinaria: " << observacionD << endl;
    cout << "Observacion de rendimiento: " << observacionR << endl;

    system("pause");
    return 0;
}




