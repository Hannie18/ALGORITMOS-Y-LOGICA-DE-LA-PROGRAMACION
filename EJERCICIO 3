	Escribir "Ingrese lado C: "
	Leer ladoC
	Escribir "Ingrese altura a la base: "
	Leer alturaBase
	Escribir "Ingrese angulo principal (grados): "
	Leer anguloPrincipal
	
	Si (ladoA + ladoB <= ladoC) O (ladoA + ladoC <= ladoB) O (ladoB + ladoC <= ladoA) Entonces
		esValido <- "NO VALIDO"
		clasificacionLados <- "NO APLICA"
		clasificacionAngulos <- "NO APLICA"
		areaTriangulo <- 0
		mensajeConsistencia <- "NO SE PUEDE ANALIZAR"
	SiNo
		esValido <- "VALIDO"
		
		
		Si ladoA = ladoB Y ladoB = ladoC Entonces
			clasificacionLados <- "EQUILATERO"
