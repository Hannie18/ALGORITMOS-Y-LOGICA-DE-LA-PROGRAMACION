C++
#include <iostream>
#include <string>

using namespace std;

int main() {
    double ladoA, ladoB, ladoC, alturaBase, anguloPrincipal;
    string esValido, clasificacionLados, clasificacionAngulos, mensajeConsistencia;
    double areaTriangulo, ladoMayor;


    cout << "Ingrese lado A: "<<endl;
    cin >> ladoA;
    cout << "Ingrese lado B: "<<endl;
    cin >> ladoB;
    cout << "Ingrese lado C: "<<endl;
    cin >> ladoC;
    cout << "Ingrese altura a la base: "<<endl;
    cin >> alturaBase;
    cout << "Ingrese angulo principal "<<endl;
    cin >> anguloPrincipal;


    if ((ladoA + ladoB <= ladoC) || (ladoA + ladoC <= ladoB) || (ladoB + ladoC <= ladoA)) {
        esValido = "NO VALIDO";
        clasificacionLados = "NO APLICA";
        clasificacionAngulos = "NO APLICA";
        areaTriangulo = 0;
        mensajeConsistencia = "NO SE PUEDE ANALIZAR";
    } else {
        esValido = "VALIDO";


        if (ladoA == ladoB && ladoB == ladoC) {
            clasificacionLados = "EQUILATERO";
        } else if (ladoA == ladoB || ladoA == ladoC || ladoB == ladoC) {
            clasificacionLados = "ISOSCELES";
        } else {
            clasificacionLados = "ESCALENO";
        }


        if (anguloPrincipal == 90) {
            clasificacionAngulos = "RECTANGULO";
        } else if (anguloPrincipal < 90) {
            clasificacionAngulos = "ACUTANGULO";
        } else {
            clasificacionAngulos = "OBTUSANGULO";
        }


        areaTriangulo = (ladoA * alturaBase) / 2;


        ladoMayor = ladoA;
        if (ladoB > ladoMayor) ladoMayor = ladoB;
        if (ladoC > ladoMayor) ladoMayor = ladoC;


        if (alturaBase > ladoMayor) {
            mensajeConsistencia = "ADVERTENCIA: ALTURA INCONSISTENTE";
        } else {
            mensajeConsistencia = "ALTURA CONSISTENTE";
        }
    }

    cout << "\n=== RESULTADO ANALISIS TRIANGULO ===" << endl;
    cout << "VALIDEZ: " << esValido << endl;
    cout << "POR LADOS: " << clasificacionLados << endl;
    cout << "POR ANGULOS: " << clasificacionAngulos << endl;
    cout << "AREA: " << areaTriangulo << endl;
    cout << "CONSISTENCIA: " << mensajeConsistencia << endl;

    return 0;
}



PSeINT

