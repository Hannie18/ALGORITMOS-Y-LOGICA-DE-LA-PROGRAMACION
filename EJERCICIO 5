#include <iostream>

using namespace std;

int main() {
    double saldoUsuario, montoSolicitado, saldoRestanteUsuario, efectivoCajeroRestante;
    int billetes20, billetes10, billetes5, billetes1;
    int necesarios20, necesarios10, necesarios5, necesarios1;
    int entregados20, entregados10, entregados5, entregados1;
    int resto1, resto2;
    string mensajeOperacion;

    cout << "======================= CAJERO AUTOMATICO =========================" << endl;


    cout << "Su saldo disponible: "<<endl;
    cin >> saldoUsuario;
    cout << "Monto a retirar: "<<endl;
    cin >> montoSolicitado;
    cout << "Inventario cajero - Billetes de 20: "<<endl;
    cin >> billetes20;
    cout << "Billetes de 10: "<<endl;
    cin >> billetes10;
    cout << "Billetes de 5: "<<endl;
    cin >> billetes5;
    cout << "Billetes de 1: "<<endl;
    cin >> billetes1;

    if (montoSolicitado <= 0 || montoSolicitado > saldoUsuario) {
        mensajeOperacion = "ERROR: MONTO INVALIDO";
        entregados20 = entregados10 = entregados5 = entregados1 = 0;
        saldoRestanteUsuario = saldoUsuario;
        efectivoCajeroRestante = billetes20*20.0 + billetes10*10.0 + billetes5*5.0 + billetes1*1.0;
    } else {

        necesarios20 = (int)(montoSolicitado / 20);
        resto1 = (int)(montoSolicitado) % 20;
        necesarios10 = resto1 / 10;
        resto2 = resto1 % 10;
        necesarios5 = resto2 / 5;
        necesarios1 = resto2 % 5;


        if (necesarios20 > billetes20 || necesarios10 > billetes10 ||
            necesarios5 > billetes5 || necesarios1 > billetes1) {
            mensajeOperacion = "ERROR: SIN BILLETES SUFICIENTES";
            entregados20 = entregados10 = entregados5 = entregados1 = 0;
            saldoRestanteUsuario = saldoUsuario;
            efectivoCajeroRestante = billetes20*20.0 + billetes10*10.0 + billetes5*5.0 + billetes1*1.0;
        } else {

            entregados20 = necesarios20;
            entregados10 = necesarios10;
            entregados5 = necesarios5;
            entregados1 = necesarios1;

            saldoRestanteUsuario = saldoUsuario - montoSolicitado;
            efectivoCajeroRestante = (billetes20*20.0 + billetes10*10.0 + billetes5*5.0 + billetes1*1.0) - montoSolicitado;

            mensajeOperacion = "OPERACION EXITOSA";
        }
    }

    cout << "\n=== RESULTADO OPERACION ===" << endl;
    cout << "BILLETES 20: " << entregados20 << endl;
    cout << "BILLETES 10: " << entregados10 << endl;
    cout << "BILLETES 5: " << entregados5 << endl;
    cout << "BILLETES 1: " << entregados1 << endl;
    cout << "SALDO RESTANTE: $" << saldoRestanteUsuario << endl;
    cout << "EFECTIVO CAJERO: $" << efectivoCajeroRestante << endl;
    cout << "MENSAJE: " << mensajeOperacion << endl;

    return 0;
}




